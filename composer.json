{
    "name": "flashmandu/app-sdk",
    "description": "Public SDK and contracts for Flashmandu app/plugin developers.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Flashmandu\\AppSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@php vendor/bin/pest"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
